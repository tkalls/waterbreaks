# Copy to .env and fill in.

VITE_SOLANA_NETWORK=devnet
# Optional: custom RPC if the public devnet endpoint is rate-limited
# VITE_RPC_URL=https://api.devnet.solana.com

# Set to "anchor" once `anchor deploy` gives you a real program ID and IDL.
VITE_PLACE_BET_MODE=fallback

# Fallback mode only: any devnet wallet pubkey that will receive demo stakes.
VITE_TREASURY_PUBKEY=

# Anchor mode only: the deployed program ID (also update declare_id! in lib.rs).
VITE_PROGRAM_ID=
